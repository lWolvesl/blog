  <script>
    const DOMAIN = '1.wolves.top';
    const STATUS_API = 'https://ark.wolves.top/api/list';
    const FALLBACK_SERVERS = [
      { id: 1, name: '孤岛', online: false, count: 0, players: [] },
      { id: 2, name: '仙境', online: false, count: 0, players: [] },
      { id: 3, name: '畸变', online: false, count: 0, players: [] },
      { id: 4, name: '创世1', online: false, count: 0, players: [] },
      { id: 5, name: '灭绝', online: false, count: 0, players: [] },
      { id: 6, name: '创世2', online: false, count: 0, players: [] },
      { id: 7, name: '维京', online: false, count: 0, players: [] },
    ];

    function initDownloadConfirmation() {
      const downloadCard = document.getElementById('downloadCard') as HTMLAnchorElement | null;
      if (!downloadCard) return;

      downloadCard.addEventListener('click', (event) => {
        event.preventDefault();

        const fileName = downloadCard.getAttribute('download') || '中文修复工具';
        const confirmed = window.confirm(`确认下载 ${fileName} 吗？`);
        if (!confirmed) return;

        const link = document.createElement('a');
        link.href = downloadCard.href;
        link.download = fileName;
        document.body.appendChild(link);
        link.click();
        link.remove();
      });
    }

    function extractARecord(data: any): string | null {
      if (data.Status !== 0 || !data.Answer) return null;
      for (const ans of data.Answer) {
        if (ans.type === 1) return ans.data;
      }
      return null;
    }

    async function resolveIp(domain: string): Promise<string | null> {
      const resolvers = [
        { url: `https://dns.alidns.com/resolve?name=${encodeURIComponent(domain)}&type=1` },
        { url: `https://cloudflare-dns.com/dns-query?name=${encodeURIComponent(domain)}&type=A`, headers: { Accept: 'application/dns-json' } }
      ];

      const startTime = Date.now();

      for (const resolver of resolvers) {
        const elapsed = Date.now() - startTime;
        const remaining = 8000 - elapsed;
        if (remaining <= 0) break;

        const controller = new AbortController();
        const timer = setTimeout(() => controller.abort(), Math.min(2000, remaining));

        try {
          const res = await fetch(resolver.url, {
            signal: controller.signal,
            headers: resolver.headers || {}
          });
          clearTimeout(timer);
          const data = await res.json();
          const ip = extractARecord(data);
          if (ip) return ip;
        } catch {
          clearTimeout(timer);
        }
      }

      return null;
    }

    function setReady(card: HTMLElement, ip: string, port: string) {
      const url = `steam://run/346110//+connect%20${ip}:${port}`;
      card.dataset.url = url;
      card.classList.add('ready');

      const addr = card.querySelector('.addr') as HTMLElement;
      addr.textContent = `${ip}:${port}`;

      card.addEventListener('click', () => {
        window.location.href = url;
      });
    }

    function setError(card: HTMLElement, message: string) {
      card.classList.add('error');
      const addr = card.querySelector('.addr') as HTMLElement;
      addr.textContent = message;
      addr.style.color = '#c46a6a';
    }

    function updateServerCard(server: any) {
      const card = document.querySelector(`[data-server-id="${server.id}"]`) as HTMLElement | null;
      if (!card) return;

      const players = Array.isArray(server.players) ? server.players : [];
      const count = Number(server.count || players.length || 0);
      const status = card.querySelector('.status-corner') as HTMLElement;
      const playerCount = card.querySelector('.player-count') as HTMLElement;
      const playerList = card.querySelector('.players') as HTMLUListElement;

      card.classList.toggle('online', Boolean(server.online));
      card.classList.toggle('offline', !server.online);
      status.setAttribute('aria-label', server.online ? `在线，${count}/10` : '离线');
      playerCount.textContent = server.online ? `${count}/10` : '';
      playerList.textContent = '';

      if (!server.online) {
        return;
      }

      if (players.length === 0) {
        const empty = document.createElement('li');
        empty.textContent = '暂无玩家';
        playerList.appendChild(empty);
        return;
      }

      for (const player of players) {
        const item = document.createElement('li');
        item.textContent = String(player);
        playerList.appendChild(item);
      }
    }

    async function loadServerStatus() {
      try {
        const response = await fetch(STATUS_API);
        if (!response.ok) throw new Error(`HTTP ${response.status}`);

        const data = await response.json();
        const servers = Array.isArray(data.servers) ? data.servers : FALLBACK_SERVERS;
        for (const server of servers) updateServerCard(server);
      } catch (error) {
        for (const server of FALLBACK_SERVERS) updateServerCard(server);
        console.error('Failed to load server status:', error);
      }
    }

    async function init() {
      loadServerStatus();

      const ip = await resolveIp(DOMAIN);
      if (!ip) {
        setError(document.getElementById('card1')!, 'DNS 解析失败');
        setError(document.getElementById('card2')!, 'DNS 解析失败');
        setError(document.getElementById('card3')!, 'DNS 解析失败');
        setError(document.getElementById('card4')!, 'DNS 解析失败');
        setError(document.getElementById('card5')!, 'DNS 解析失败');
        setError(document.getElementById('card6')!, 'DNS 解析失败');
        setError(document.getElementById('card7')!, 'DNS 解析失败');
        return;
      }

      const card1 = document.getElementById('card1')!;
      const card2 = document.getElementById('card2')!;
      const card3 = document.getElementById('card3')!;
      const card4 = document.getElementById('card4')!;
      const card5 = document.getElementById('card5')!;
      const card6 = document.getElementById('card6')!;
      const card7 = document.getElementById('card7')!;
      setReady(card1, ip, card1.dataset.port!);
      setReady(card2, ip, card2.dataset.port!);
      setReady(card3, ip, card3.dataset.port!);
      setReady(card4, ip, card4.dataset.port!);
      setReady(card5, ip, card5.dataset.port!);
      setReady(card6, ip, card6.dataset.port!);
      setReady(card7, ip, card7.dataset.port!);
    }

    initDownloadConfirmation();
    init();
  </script>
</body>
</html>
